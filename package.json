    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "sass": "^1.89.0",
    "vue-tsc": "^3.1.1"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "pngjs": "^7.0.0",
    "simple-icons": "^16.14.0"
