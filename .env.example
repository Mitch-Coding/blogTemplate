# Optional: enable the AI assistant on the portfolio homepage.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: override the default public assistant prompt.
PORTFOLIO_SYSTEM_PROMPT=You are the portfolio assistant for Example Author. Answer only questions about the example profile, skills, projects, work style, and collaboration. If a question is unrelated, politely redirect it back to the portfolio.

# Public site origin used for RSS, sitemap, robots, canonical, and OG URLs.
NUXT_PUBLIC_SITE_URL=https://example.com
